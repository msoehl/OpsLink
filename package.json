{
  "name": "openefb",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source Electronic Flight Bag for flight simulators",
  "author": "Moritz Soehl",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json",
    "electron:pack": "npm run build:electron && electron-builder",
    "electron:release": "npm run build:electron && electron-builder --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.openefb.app",
    "productName": "OpenEFB",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "artifactName": "OpenEFB-${arch}.dmg"
    },
    "win": {
      "target": "nsis",
      "artifactName": "OpenEFB-Setup.exe"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "OpenEFB.AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "msoehl",
      "repo": "openefb"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
